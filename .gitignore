# .gitignore for Unity3D projects

# Unity generated files
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/UserSettings/
/Packages/packages-lock.json

# Memory Captures (snapshots) can be binary files
*.snap

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# Build Size Tools
SerializedBuildInfo/
**/SerializedBuildInfo/
*.abbuildinfo

# macOS generated files
.DS_Store
._*
.Spotlight-V100
.Trashes

# Temporary files
*.tmp
*.bak
*.swp
*.bak.*
*~.tmp

# Ignore JetBrains Rider config files
.idea/
*.DotSettings

# Ignore Visual Studio Code config files
.vscode/

# Ignore Unity specific settings
*.csharp.rsp
#*.asmdef

# Unity Addressables generated
Assets/AddressableAssetsData/link.xml
Assets/AddressableAssetsData/link.xml.meta

# Unity Addressables build artifacts
**/addressables_content_state.bin
**/addressables_content_state.bin.meta


# End of .gitignore
